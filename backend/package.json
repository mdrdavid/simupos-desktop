{
  "name": "simpos-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc && echo Build completed successfully!",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "format": "npx prettier --write .",
    "migration:generate": "npm run typeorm migration:generate",
    "migration:run": "npm run typeorm migration:run",
    "migration:revert": "npm run typeorm migration:revert",
    "typeorm:run-migrations": " npm run typeorm -- migration:run -d src/config/database.ts",
    "typeorm:generate-migration": "npm run typeorm -- migration:generate -o -d src/config/database.ts ./src/migrations/$npm_config_name",
    "typeorm:create-migration": "npm run typeorm -- migration:create -o ./src/migrations/$npm_config_name",
    "typeorm:update-migration": "npm run typeorm:generate-migration && npm run typeorm:create-migration && npm run typeorm:run-migrations",
    "typeorm:revert-migration": "npm run typeorm -- migration:revert -d src/config/database.ts",
    "migrate-db": "npm run typeorm:update-migration",
    "release": "npm run migrate-db",
    "deploy": "bash deploy.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdrdavid/simpos-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mdrdavid/simpos-api/issues"
  },
  "homepage": "https://github.com/mdrdavid/simpos-api#readme",
  "dependencies": {
    "ansi-colors": "^4.1.3",
    "bcryptjs": "^3.0.2",
    "class-validator": "^0.14.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "ssl-root-cas": "^1.3.1",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.30",
    "nodemon": "^3.1.10",
    "prettier": "3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
